# formr instance URL (local dev or production)
FORMR_BASE_URL=http://localhost

# API credentials — create at <base_url>/admin/account#api
# Requires admin >= 2
FORMR_CLIENT_ID=your_32_hex_client_id
FORMR_CLIENT_SECRET=your_64_hex_client_secret

# Flowchart Generator URL (used by open_flowchart tool)
# FLOWCHART_URL=https://formr-flowchart-test.pages.dev
